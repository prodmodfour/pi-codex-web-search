{
  "name": "pi-codex-web-search",
  "version": "0.0.0",
  "description": "Pi extension package for a Codex CLI-backed web search tool.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "codex",
    "web-search"
  ],
  "files": [
    "extensions",
    "src",
    "docs",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/codex-web-search.ts"
    ]
  },
  "scripts": {
    "quality": "bash scripts/quality-gate.sh",
    "check:shell": "bash scripts/check-shell-syntax.sh",
    "guard:secrets": "bash scripts/check-no-secrets.sh",
    "guard:generated": "bash scripts/check-no-generated-private-files.sh",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.mjs",
    "build": "npm run typecheck",
    "pack:check": "node scripts/check-package-contents.mjs",
    "smoke:codex": "node scripts/smoke-real-codex-search.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.17.19",
    "typescript": "^5.7.3"
  }
}
